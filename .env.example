# Medinovaqbank frontend env (Vite). Copy to `.env` and adjust for your setup.
# Only VITE_* vars are exposed to the browser — never put secrets here.

# Backend REST base URL (includes the /api/v1 global prefix).
VITE_API_URL=http://localhost:3000/api/v1

# Realtime gateway origin (socket.io). Same host/port as the API, no /api/v1.
VITE_WS_URL=http://localhost:3000

# Paystack PUBLIC key — only needed if checkout uses Paystack inline.
# Otherwise the backend's /payments/initialize returns an authorizationUrl to open.
# VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxx
